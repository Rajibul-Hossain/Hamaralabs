rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    function isStaffOrAdmin() {
      let r = getUserRole();
      return r == 'admin' || r == 'platform-admin' || r == 'super-admin' || r == 'atl-incharge' || r == 'school-admin' || r == 'mentor';
    }
    
    function isAdmin() {
      let r = getUserRole();
      return r == 'admin' || r == 'platform-admin' || r == 'super-admin';
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isStaffOrAdmin());
      allow delete: if isSignedIn() && isAdmin();
    }

    match /schools/{schoolId} {
      allow read, create: if isSignedIn();
      allow update, delete: if isSignedIn() && isAdmin();
    }
    
    match /mentorSchoolAssignments/{docId} {
      allow read, create: if isSignedIn();
      allow update, delete: if isSignedIn() && isStaffOrAdmin();
    }
    
    match /inchargeSchoolAssignments/{docId} {
      allow read, create: if isSignedIn();
      allow update, delete: if isSignedIn() && isAdmin();
    }

    match /tasks/{taskId} {
      allow read, update: if isSignedIn();
      allow create, delete: if isSignedIn() && isStaffOrAdmin();
    }

    match /tasks/{taskId}/doubts/{doubtId} {
      allow read, create, update: if isSignedIn();
      allow delete: if isSignedIn() && isStaffOrAdmin();
    }

    match /tinkering_activities/{taId} {
      allow read, update: if isSignedIn();
      allow create, delete: if isSignedIn() && isStaffOrAdmin();
    }

    match /competitions/{compId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn() && isStaffOrAdmin();
    }

    match /competition_assignments/{assignId} {
      allow read, update: if isSignedIn();
      allow create, delete: if isSignedIn() && isStaffOrAdmin();
    }
  }
}